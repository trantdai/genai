{
  "version": "1.0",
  "_comment": "Generic Python project settings for Claude Code. Customize per project in settings.local.json",
  "permissions": {
    "file_operations": {
      "read": true,
      "write": true,
      "create": true,
      "delete": false,
      "execute": false
    },
    "command_execution": {
      "enabled": true,
      "restricted_mode": true,
      "timeout_seconds": 300,
      "working_directory_restriction": true
    },
    "network_access": {
      "enabled": true,
      "allow_localhost": true,
      "allow_external": false,
      "allowed_domains": [
        "pypi.org",
        "files.pythonhosted.org",
        "github.com",
        "raw.githubusercontent.com"
      ]
    },
    "browser_access": {
      "enabled": false,
      "allow_file_urls": false
    }
  },
  "command_restrictions": {
    "allowed_commands": [
      "python",
      "python3",
      "pip",
      "pip3",
      "poetry",
      "pipenv",
      "pytest",
      "coverage",
      "black",
      "ruff",
      "mypy",
      "bandit",
      "safety",
      "pip-audit",
      "detect-secrets",
      "pre-commit",
      "git",
      "docker",
      "docker-compose",
      "make",
      "which",
      "echo",
      "cat",
      "ls",
      "pwd",
      "find",
      "grep",
      "head",
      "tail",
      "wc",
      "sort",
      "uniq",
      "sed",
      "awk",
      "curl",
      "wget",
      "tree",
      "mkdir",
      "touch",
      "cp",
      "mv"
    ],
    "blocked_commands": [
      "rm",
      "rmdir",
      "dd",
      "format",
      "fdisk",
      "mkfs",
      "mount",
      "umount",
      "sudo",
      "su",
      "chmod",
      "chown",
      "passwd",
      "userdel",
      "usermod",
      "crontab",
      "systemctl",
      "service",
      "kill",
      "killall",
      "pkill",
      "shutdown",
      "reboot",
      "halt",
      "init"
    ],
    "dangerous_flags": [
      "-rf",
      "-f",
      "--force",
      "--delete",
      "--remove",
      "--recursive"
    ]
  },
  "file_restrictions": {
    "editable_patterns": [
      "*.py",
      "*.pyi",
      "*.pyx",
      "*.pxd",
      "*.md",
      "*.rst",
      "*.txt",
      "*.yaml",
      "*.yml",
      "*.json",
      "*.toml",
      "*.cfg",
      "*.ini",
      "*.conf",
      "requirements*.txt",
      "pyproject.toml",
      "poetry.lock",
      "Pipfile",
      "Pipfile.lock",
      "setup.py",
      "setup.cfg",
      "tox.ini",
      "pytest.ini",
      ".pre-commit-config.yaml",
      ".github/workflows/*.yml",
      ".github/workflows/*.yaml",
      "Dockerfile*",
      "docker-compose*.yml",
      "docker-compose*.yaml",
      "Makefile",
      ".gitignore",
      ".dockerignore",
      "*.env.example",
      "*.env.template"
    ],
    "readonly_patterns": [
      ".git/*",
      "__pycache__/*",
      "*.pyc",
      "*.pyo",
      "*.pyd",
      ".pytest_cache/*",
      ".coverage",
      "htmlcov/*",
      ".mypy_cache/*",
      ".ruff_cache/*",
      "dist/*",
      "build/*",
      "*.egg-info/*",
      ".venv/*",
      "venv/*",
      "env/*",
      "node_modules/*"
    ],
    "forbidden_patterns": [
      "*.env",
      ".env.local",
      ".env.production",
      "*.key",
      "*.pem",
      "*.p12",
      "*.pfx",
      "*.jks",
      "*.keystore",
      "*secret*",
      "*password*",
      "*credential*",
      "*.sqlite",
      "*.db",
      "/etc/*",
      "/var/*",
      "/usr/*",
      "/bin/*",
      "/sbin/*",
      "/sys/*",
      "/proc/*"
    ],
    "max_file_size_mb": 10,
    "max_files_per_operation": 50
  },
  "environment_variables": {
    "allowed_read": [
      "PATH",
      "PYTHONPATH",
      "VIRTUAL_ENV",
      "CONDA_DEFAULT_ENV",
      "POETRY_ACTIVE",
      "PWD",
      "HOME",
      "USER",
      "SHELL",
      "TERM",
      "LANG",
      "LC_*",
      "TZ",
      "CI",
      "GITHUB_*",
      "PYTEST_*",
      "COVERAGE_*"
    ],
    "blocked_read": [
      "*SECRET*",
      "*PASSWORD*",
      "*KEY*",
      "*TOKEN*",
      "*CREDENTIAL*",
      "AWS_*",
      "AZURE_*",
      "GCP_*",
      "DATABASE_URL",
      "DB_*"
    ],
    "allowed_set": [
      "PYTHONPATH",
      "PYTEST_*",
      "COVERAGE_*"
    ]
  },
  "project_structure": {
    "src_layout": true,
    "test_directory": "tests",
    "docs_directory": "docs",
    "config_files": [
      "pyproject.toml",
      "setup.py",
      "requirements.txt"
    ]
  },
  "logging": {
    "level": "INFO",
    "file": ".claude/logs/claude.log",
    "max_size_mb": 10,
    "backup_count": 5,
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s"
  }
}
