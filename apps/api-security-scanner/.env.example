# API Security Scanner - Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Logging Configuration
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# HTTP Client Configuration
DEFAULT_TIMEOUT=30  # Request timeout in seconds
DEFAULT_CONCURRENCY=10  # Maximum concurrent requests

# Scanner Configuration
MAX_ENDPOINTS=100  # Maximum endpoints to discover
MAX_SCAN_DURATION=300  # Maximum scan duration in seconds (5 minutes)

# Report Configuration
DEFAULT_REPORT_PATH=./scan-report.json  # Default report output path

# Development/Debug
DEBUG=false  # Enable debug mode
