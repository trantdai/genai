{
  "_comment": "Local settings overrides. Copy to settings.local.json and customize.",

  "permissions": {
    "command_execution": {
      "timeout_seconds": 600
    },
    "network_access": {
      "allow_external": true,
      "allowed_domains": ["your-private-registry.com"]
    }
  },

  "command_restrictions": {
    "allowed_commands": ["jupyter", "ipython", "conda"]
  },

  "file_restrictions": {
    "editable_patterns": ["scripts/*.sh", "config/*.yaml"],
    "max_file_size_mb": 25
  },

  "environment_variables": {
    "allowed_read": ["DEBUG", "LOG_LEVEL", "YOUR_PROJECT_*"]
  },

  "custom_tools": {
    "custom_formatter": {
      "command": "ruff",
      "args": ["format", "--line-length", "120"],
      "file_patterns": ["*.py"]
    }
  },

  "code_analysis": {
    "thresholds": {
      "max_complexity": 20,
      "max_function_length": 75
    }
  },

  "auto_formatting": {
    "enabled": true,
    "on_save": true
  },

  "testing": {
    "coverage_threshold": 70,
    "pytest_args": ["-v", "--tb=short"]
  },

  "performance": {
    "max_concurrent_tasks": 8,
    "memory_limit_mb": 2048
  },

  "logging": {
    "level": "DEBUG"
  }
}
